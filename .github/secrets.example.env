# ============================================================================
#  GitHub Actions — SECRETS & VARIABLES (TEMPLATE / MẪU)
# ============================================================================
#  File này CHỈ chứa giá trị MẪU (placeholder) → AN TOÀN để commit.
#  KHÔNG điền khóa thật vào đây. Khóa thật nạp thẳng lên GitHub:
#     Repo → Settings → Secrets and variables → Actions
#  (hoặc dùng `gh secret set` — xem cuối file).
#
#  Phân biệt:
#    • Secrets   = giá trị nhạy cảm (khóa, mật khẩu) — bị che trong log.
#    • Variables = giá trị không nhạy cảm (vd URL công khai sau khi deploy).
# ============================================================================


# ─── SECRETS (tab "Secrets") ────────────────────────────────────────────────

# 1) Quyền cho GitHub Actions deploy lên Google Cloud
#    Lấy ở: GCP Console → IAM & Admin → Service Accounts → Keys → Add key (JSON).
#    Service account cần role: Cloud Run Admin + Cloud Build Editor +
#    Artifact Registry Admin + Storage Admin + Service Account User.
#    Dán TOÀN BỘ nội dung file JSON vào secret này (đừng để vào file này).
GCP_SA_KEY={"type":"service_account","project_id":"...","private_key":"-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n","client_email":"...@....iam.gserviceaccount.com",...}
GCP_PROJECT_ID=ten-project-id

# 2) Khóa các dịch vụ AI / DB mà app cần lúc chạy
GEMINI_API_KEY=AIzaSy_xxx_doi_bang_khoa_that_tu_aistudio_google_com
QDRANT_URL=https://xxxxxxxx-xxxx.aws.cloud.qdrant.io:6333
QDRANT_API_KEY=qdr_xxx_lay_o_qdrant_cloud_dashboard
NEO4J_URI=neo4j+s://xxxxxxxx.databases.neo4j.io
NEO4J_PASSWORD=mat_khau_neo4j_aura

# 3) PostgreSQL (BẮT BUỘC — chat bị auth-gate). Free: Neon / Supabase.
#    LƯU Ý: POSTGRES_HOST chỉ là HOST, KHÔNG kèm "/tendatabase" ở cuối.
POSTGRES_HOST=ep-xxx-xxx-pooler.region.aws.neon.tech
POSTGRES_DB=neondb
POSTGRES_USER=neondb_owner
POSTGRES_PASSWORD=mat_khau_postgres

# 4) Bảo mật ứng dụng
#    JWT_SECRET: chuỗi ngẫu nhiên bạn TỰ tạo (không lấy từ dịch vụ nào).
#    Sinh bằng:  python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET=chuoi_ngau_nhien_tu_sinh
#    GOOGLE_CLIENT_ID: GCP Console → APIs & Services → Credentials → OAuth client (Web).
GOOGLE_CLIENT_ID=1234567890-abcxyz.apps.googleusercontent.com


# ─── VARIABLES (tab "Variables") ────────────────────────────────────────────

# URL Cloud Run của backend — chỉ có SAU lần deploy backend đầu tiên.
# Điền vào Variable này rồi chạy lại workflow "Deploy Frontend".
BACKEND_URL=https://orchestrator-xxxxxxxxxx-as.a.run.app


# ============================================================================
#  CÁCH NẠP NHANH BẰNG GitHub CLI (gh) — PowerShell
# ============================================================================
#  Secret thường:
#     gh secret set JWT_SECRET --body "gia-tri-that"
#  Secret là file JSON (PowerShell không dùng "<", phải pipe):
#     Get-Content gcp-sa-key.json -Raw | gh secret set GCP_SA_KEY
#  Variable:
#     gh variable set BACKEND_URL --body "https://...run.app"
#  Kiểm tra:  gh secret list   /   gh variable list
# ============================================================================
